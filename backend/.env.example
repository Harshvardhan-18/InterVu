# ── Google AI ──────────────────────────────────────────────────────────────────
# Documenting key rotation pool support (add as many as needed)
GOOGLE_API_KEY_1=your_google_api_key_1_here
GOOGLE_API_KEY_2=your_google_api_key_2_here

# Fallback/single key usage (if numbered keys are not set)
GOOGLE_API_KEY=your_single_google_api_key_here

# ── Search ─────────────────────────────────────────────────────────────────────
TAVILY_API_KEY=your_tavily_api_key_here
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/intervu

# ── ChromaDB ───────────────────────────────────────────────────────────────────
CHROMA_PATH=./chroma_db
CHROMA_COLLECTION=intervu_kb

# ── App ────────────────────────────────────────────────────────────────────────
ENV=development
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000
